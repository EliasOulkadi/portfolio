{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["frontend/**"]
      }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "backend/server.js" },
    { "src": "/admin",    "dest": "backend/server.js" },
    { "src": "/panel",    "dest": "backend/server.js" },
    { "src": "/css/(.*)",  "dest": "frontend/css/$1" },
    { "src": "/js/(.*)",   "dest": "frontend/js/$1" },
    { "src": "/(.*)",     "dest": "backend/server.js" }
  ]
}
